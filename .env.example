# Retail Order Sync Hub — environment template
# Copy to `.env` and fill in. `.env` is gitignored.
# Values are filled phase by phase; phase 0 only documents the shape.

# --- General ---
ENV=local
LOG_LEVEL=INFO

# --- Operational Postgres (app_db) — Phase 1 ---
APP_DB_HOST=localhost
APP_DB_PORT=5433
APP_DB_USER=rosh
APP_DB_PASSWORD=change-me
APP_DB_NAME=rosh

# --- Odoo — Phase 1 ---
ODOO_URL=http://localhost:8069
ODOO_DB=odoo
ODOO_USER=admin
ODOO_PASSWORD=admin

# --- MercadoLibre OAuth (sandbox) — Phase 2 ---
ML_CLIENT_ID=
ML_CLIENT_SECRET=
ML_REDIRECT_URI=http://localhost:8000/oauth/mercadolibre/callback

# --- paris-mock — Phase 2 ---
PARIS_API_KEY=change-me
PARIS_API_SECRET=change-me

# --- Pub/Sub emulator — Phase 3 ---
PUBSUB_EMULATOR_HOST=localhost:8085
PUBSUB_PROJECT_ID=retail-order-sync-local

# --- OpenTelemetry — Phase 1/6 ---
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=retail-order-sync-hub

# --- BigQuery / dbt — Phase 7 ---
GCP_PROJECT_ID=
BQ_DATASET=retail_order_sync

# --- MCP server IAM — Phase 8-9 ---
# Format: "<token>:<scope1>,<scope2>;..." — semicolon-separated token entries
# Roles:
#   viewer   → orders.read,metrics.read
#   operator → orders.read,metrics.read,outbox.retry,dlq.replay
#   admin    → orders.read,metrics.read,outbox.retry,dlq.replay,dlq.admin
MCP_STATIC_TOKENS=viewer-token:orders.read,metrics.read;op-token:orders.read,metrics.read,outbox.retry,dlq.replay;admin-token:orders.read,metrics.read,outbox.retry,dlq.replay,dlq.admin
